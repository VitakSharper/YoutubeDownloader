<Window x:Class="YoutubeDownloader.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:YoutubeDownloader.App.Converters"
        Title="Liudochka Youtube Downloader"
        Icon="app.ico"
        Height="640" Width="680" MinWidth="580" MinHeight="560"
        WindowStartupLocation="CenterScreen"
        Topmost="{Binding AlwaysOnTop}"
        FontFamily="Segoe UI" TextOptions.TextFormattingMode="Ideal">

    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#4C1D95" Offset="0" />
            <GradientStop Color="#A21CAF" Offset="0.55" />
            <GradientStop Color="#0E7490" Offset="1" />
        </LinearGradientBrush>
    </Window.Background>

    <Window.Resources>
        <conv:InverseBoolConverter x:Key="InverseBool" />
        <conv:NullToVisibilityConverter x:Key="NullToVis" />
        <conv:NonEmptyToVisibilityConverter x:Key="NonEmptyToVis" />

        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#D8B4FE" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="2,0,0,5" />
        </Style>

        <!-- Rounded glass text box -->
        <Style x:Key="GlassTextBox" TargetType="TextBox">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="CaretBrush" Value="White" />
            <Setter Property="SelectionBrush" Value="#7C3AED" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bd" CornerRadius="9" Background="#26FFFFFF"
                                BorderBrush="#66FFFFFF" BorderThickness="1">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#F0ABFC" />
                                <Setter TargetName="bd" Property="Background" Value="#33FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Light dropdown -->
        <Style x:Key="Combo" TargetType="ComboBox">
            <Setter Property="Foreground" Value="#1E1B2E" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="9,5" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Width" Value="240" />
        </Style>

        <!-- Vibrant gradient button -->
        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="18,9" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#EC4899" Offset="0" />
                                    <GradientStop Color="#8B5CF6" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.9" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.78" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Small ghost button (history actions) -->
        <Style x:Key="ChipButton" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="11.5" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="11,5" />
            <Setter Property="Margin" Value="6,0,0,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="7" Background="#2EFFFFFF"
                                BorderBrush="#3DFFFFFF" BorderThickness="1" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#4DFFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.7" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Pill tab headers -->
        <Style x:Key="PillTab" TargetType="TabItem">
            <Setter Property="Foreground" Value="#C4B5FD" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="bd" CornerRadius="9" Padding="18,7" Margin="0,0,8,0"
                                Background="#1FFFFFFF" BorderThickness="0">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#33FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="White" />
                                <Setter TargetName="bd" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#EC4899" Offset="0" />
                                            <GradientStop Color="#8B5CF6" Offset="1" />
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Cassette background motif (behind the card) -->
        <Image Source="Assets/cassette.png" Stretch="Uniform" Opacity="0.30" Width="400"
               HorizontalAlignment="Center" VerticalAlignment="Center" Margin="40"
               RenderOptions.BitmapScalingMode="HighQuality" />

        <!-- Frosted card -->
        <Border Margin="18" CornerRadius="18" Background="#42140A2E"
                BorderBrush="#40FFFFFF" BorderThickness="1" Padding="24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Branded header (shared across tabs) -->
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <StackPanel Orientation="Horizontal">
                    <Image Source="app.ico" Width="46" Height="46"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                    <StackPanel VerticalAlignment="Center" Margin="14,0,0,0">
                        <TextBlock FontSize="21">
                            <Run Text="Liudochka" FontWeight="Bold" Foreground="#F0ABFC" />
                            <Run Text=" Youtube Downloader" FontWeight="SemiBold" Foreground="White" />
                        </TextBlock>
                        <TextBlock Text="Grab audio &amp; video from any YouTube link"
                                   FontSize="11.5" Foreground="#C4B5FD" Margin="0,2,0,0" />
                    </StackPanel>
                </StackPanel>
                <CheckBox Content="Always on top" IsChecked="{Binding AlwaysOnTop}"
                          HorizontalAlignment="Right" VerticalAlignment="Center"
                          Foreground="#E9D5FF" FontSize="11.5" Cursor="Hand"
                          ToolTip="Keep this window above other windows" />
            </Grid>

            <!-- Tabs -->
            <TabControl Grid.Row="1" SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}">

                <!-- ===== DOWNLOAD ===== -->
                <TabItem Header="Download" Style="{StaticResource PillTab}">
                    <Grid Margin="0,16,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- URL row, with clipboard-suggestion banner above it -->
                        <StackPanel Grid.Row="0">
                            <Border Margin="0,0,0,12" CornerRadius="10" Padding="12,9"
                                    Background="#33A855F7" BorderBrush="#5CC4B5FD" BorderThickness="1"
                                    Visibility="{Binding DetectedClipboardUrl, Converter={StaticResource NonEmptyToVis}}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Foreground="#EDE9FE"
                                               FontSize="12.5" TextWrapping="Wrap"
                                               Text="📋 Found a YouTube link on your clipboard." />
                                    <Button Grid.Column="1" Content="Use it" Style="{StaticResource ChipButton}"
                                            Command="{Binding UseDetectedLinkCommand}" />
                                    <Button Grid.Column="2" Content="✕" Style="{StaticResource ChipButton}"
                                            ToolTip="Dismiss" Command="{Binding DismissDetectedLinkCommand}" />
                                </Grid>
                            </Border>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Margin="0,0,10,0" Style="{StaticResource GlassTextBox}"
                                         Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}"
                                         IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" />
                                <Button Grid.Column="1" Content="Fetch" Style="{StaticResource AccentButton}"
                                        Command="{Binding FetchInfoCommand}" />
                            </Grid>
                        </StackPanel>

                        <!-- Video info -->
                        <Border Grid.Row="1" Margin="0,16,0,0" CornerRadius="12" Padding="14,11"
                                Background="#1FFFFFFF" BorderBrush="#2EFFFFFF" BorderThickness="1"
                                Visibility="{Binding VideoInfo, Converter={StaticResource NullToVis}}">
                            <StackPanel>
                                <TextBlock Text="{Binding VideoInfo.Title}" Foreground="White"
                                           FontSize="15" FontWeight="Bold" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding VideoInfo.Author}" Foreground="#CBD5E1"
                                           FontSize="12" Margin="0,3,0,0" />
                            </StackPanel>
                        </Border>

                        <!-- Options -->
                        <StackPanel Grid.Row="2" Margin="0,18,0,0"
                                    Visibility="{Binding VideoInfo, Converter={StaticResource NullToVis}}">
                            <TextBlock Text="FORMAT" Style="{StaticResource Label}" />
                            <ComboBox Style="{StaticResource Combo}" Margin="0,0,0,14"
                                      ItemsSource="{Binding Modes}" SelectedItem="{Binding SelectedMode}" />

                            <TextBlock Text="MP3 BITRATE" Style="{StaticResource Label}" />
                            <ComboBox Style="{StaticResource Combo}" Margin="0,0,0,6"
                                      ItemsSource="{Binding Bitrates}" SelectedItem="{Binding SelectedBitrate}" />

                            <Border CornerRadius="8" Background="#33F59E0B" Padding="10,7" Margin="0,2,0,14"
                                    Visibility="{Binding UpscaleWarning, Converter={StaticResource NullToVis}}">
                                <TextBlock Text="{Binding UpscaleWarning}" Foreground="#FCD34D"
                                           FontSize="12" TextWrapping="Wrap" />
                            </Border>

                            <TextBlock Text="VIDEO QUALITY" Style="{StaticResource Label}" />
                            <ComboBox Style="{StaticResource Combo}"
                                      ItemsSource="{Binding VideoInfo.VideoOptions}"
                                      SelectedItem="{Binding SelectedVideoQuality}"
                                      DisplayMemberPath="QualityLabel" />
                        </StackPanel>

                        <!-- Progress -->
                        <ProgressBar Grid.Row="3" Height="8" Margin="0,18,0,10" Minimum="0" Maximum="1"
                                     BorderThickness="0" Background="#22FFFFFF" Value="{Binding Progress}">
                            <ProgressBar.Foreground>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#22D3EE" Offset="0" />
                                    <GradientStop Color="#A855F7" Offset="1" />
                                </LinearGradientBrush>
                            </ProgressBar.Foreground>
                        </ProgressBar>

                        <!-- Status + action -->
                        <Grid Grid.Row="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" Foreground="#CBD5E1"
                                       FontSize="12" VerticalAlignment="Center" TextWrapping="Wrap" Margin="0,0,12,0" />
                            <Button Grid.Column="1" Content="Download" Style="{StaticResource AccentButton}"
                                    Padding="26,10" Command="{Binding DownloadCommand}" />
                        </Grid>
                    </Grid>
                </TabItem>

                <!-- ===== HISTORY ===== -->
                <TabItem Header="History" Style="{StaticResource PillTab}">
                    <Grid Margin="0,16,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Search + clear -->
                        <Grid Grid.Row="0" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0" Margin="0,0,10,0">
                                <TextBox Style="{StaticResource GlassTextBox}"
                                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="Search by title or link…" IsHitTestVisible="False"
                                           Foreground="#9C93C4" FontSize="13" Margin="14,0,0,0"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SearchText}" Value="">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                            <Button Grid.Column="1" Content="Clear all" Style="{StaticResource ChipButton}"
                                    Margin="0" VerticalAlignment="Center"
                                    Command="{Binding ClearHistoryCommand}" />
                        </Grid>

                        <!-- Empty / no-results state -->
                        <TextBlock Grid.Row="1" Text="{Binding HistoryPlaceholder}"
                                   Foreground="#A99FD0" FontSize="13" TextWrapping="Wrap" MaxWidth="360"
                                   TextAlignment="Center" HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Visibility="{Binding HistoryPlaceholder, Converter={StaticResource NullToVis}}" />

                        <!-- Grouped list -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,4,0">
                            <ItemsControl ItemsSource="{Binding HistoryGroups}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,0,0,4">
                                            <TextBlock Text="{Binding Header}" Foreground="#C4B5FD"
                                                       FontWeight="SemiBold" FontSize="11.5" Margin="2,6,0,7" />
                                            <ItemsControl ItemsSource="{Binding Entries}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border CornerRadius="10" Background="#1FFFFFFF"
                                                                BorderBrush="#2EFFFFFF" BorderThickness="1"
                                                                Padding="13,11" Margin="0,0,0,9">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>
                                                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                                                    <TextBlock Text="{Binding Title}" Foreground="White"
                                                                               FontWeight="SemiBold" FontSize="13"
                                                                               TextTrimming="CharacterEllipsis" />
                                                                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                                                        <Border CornerRadius="5" Background="#3DA855F7"
                                                                                Padding="7,2" VerticalAlignment="Center">
                                                                            <TextBlock Text="{Binding Format}" Foreground="#EDE9FE"
                                                                                       FontSize="10.5" />
                                                                        </Border>
                                                                        <TextBlock Text="{Binding TimeDisplay}" Foreground="#A99FD0"
                                                                                   FontSize="10.5" Margin="8,0,0,0"
                                                                                   VerticalAlignment="Center" />
                                                                    </StackPanel>
                                                                    <TextBlock Text="{Binding Url}" Foreground="#8E86B0"
                                                                               FontSize="10.5" TextTrimming="CharacterEllipsis"
                                                                               Margin="0,5,0,0" />
                                                                </StackPanel>
                                                                <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                                            VerticalAlignment="Center">
                                                                    <Button Content="Use" Style="{StaticResource ChipButton}"
                                                                            ToolTip="Put this link back in the download box"
                                                                            Command="{Binding DataContext.UseEntryCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                                            CommandParameter="{Binding}" />
                                                                    <Button Content="Open" Style="{StaticResource ChipButton}"
                                                                            ToolTip="Open in browser"
                                                                            Command="{Binding DataContext.OpenInBrowserCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                                            CommandParameter="{Binding}" />
                                                                    <Button Content="Folder" Style="{StaticResource ChipButton}"
                                                                            ToolTip="Show the file in Explorer"
                                                                            Visibility="{Binding FilePath, Converter={StaticResource NonEmptyToVis}}"
                                                                            Command="{Binding DataContext.OpenFolderCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                                            CommandParameter="{Binding}" />
                                                                    <Button Content="✕" Style="{StaticResource ChipButton}"
                                                                            ToolTip="Remove from history"
                                                                            Command="{Binding DataContext.RemoveEntryCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                                            CommandParameter="{Binding}" />
                                                                </StackPanel>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
        </Border>
    </Grid>
</Window>
